{
  "elements": [
    {
      "type": "Label",
      "caption": "──────────────────────────────────────────────────────────────────────"
    },
    {
      "type": "Label",
      "caption": "Docker MCP Server Konfiguration",
      "fontSize": 16,
      "bold": true
    },
    {
      "type": "Label",
      "caption": "Der MCP Server läuft extern (z.B. in einem Docker-Container). Dieses Modul verbindet sich per HTTP zum Server."
    },
    {
      "type": "Label",
      "caption": "──────────────────────────────────────────────────────────────────────"
    },
    {
      "type": "Label",
      "caption": ""
    },
    {
      "type": "Label",
      "caption": "MCP Server URL",
      "fontSize": 14,
      "bold": true
    },
    {
      "type": "Label",
      "caption": "URL des MCP-Servers (inkl. Port). Beispiele: http://localhost:4096 oder http://192.168.1.100:4096"
    },
    {
      "type": "ValidationTextBox",
      "name": "MCPServerURL",
      "caption": "MCP Server URL"
    },
    {
      "type": "Label",
      "caption": ""
    },
    {
      "type": "Label",
      "caption": "API-Schlüssel",
      "fontSize": 14,
      "bold": true
    },
    {
      "type": "Label",
      "caption": "Der API-Schlüssel muss mit dem MCP_AUTH_TOKEN im externen Server übereinstimmen. Generieren Sie einen mit: openssl rand -hex 32"
    },
    {
      "type": "PasswordTextBox",
      "name": "ApiKey",
      "caption": "API-Key"
    },
    {
      "type": "Label",
      "caption": "WICHTIG: Dieser Key muss auch im externen Servers (MCP_AUTH_TOKEN) gesetzt sein!"
    },
    {
      "type": "Label",
      "caption": ""
    },
    {
      "type": "Label",
      "caption": "Modul aktivieren",
      "fontSize": 14,
      "bold": true
    },
    {
      "type": "CheckBox",
      "name": "Active",
      "caption": "Aktiv"
    },
    {
      "type": "Label",
      "caption": "Wenn aktiviert, prüft das Modul regelmäßig (alle 60 Sekunden) die Verbindung zum MCP Server."
    },
    {
      "type": "Label",
      "caption": ""
    },
    {
      "type": "Label",
      "caption": "──────────────────────────────────────────────────────────────────────"
    },
    {
      "type": "Label",
      "caption": "Setup-Hinweise",
      "fontSize": 14,
      "bold": true
    }
  ],
  "actions": [
    {
      "type": "Button",
      "caption": "Verbindung testen",
      "onClick": "echo MCP_TestConnection($id);"
    }
  ]
}
