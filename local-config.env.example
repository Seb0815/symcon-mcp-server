# Lokale Config für start-mcp-local.sh
# Kopieren nach: cp local-config.env.example local-config.env
# Dann Werte anpassen. Passwort wird beim Start abgefragt (nicht hier eintragen).

# Symcon JSON-RPC API (mit abschließendem Slash)
# Ersetzen Sie 192.168.x.x durch die IP Ihrer SymBox.
# local-config.env wird nicht ins Git übernommen (.gitignore) – hier Ihre echte IP eintragen.
SYMCON_API_URL=http://192.168.x.x:3777/api/

# Lizenz-E-Mail für Symcon Remote Access (Basic-Auth)
SYMCON_API_USER=your-license-email@example.com

# Optional: MCP-API-Key (leer = keiner)
# MCP_AUTH_TOKEN=

# ─── Access Control ─────────────────────────────────────────────────────────
# Welche Tools dem KI-Client sichtbar sind.
#
# MCP_ACCESS_MODE
#   read-only  (Standard) – nur Lese-Tools (get_value, get_object_tree, …)
#   full                  – alle Tools inkl. Steuerung, Skripte, Events
#   custom                – Kategorien einzeln per Flag freischalten
#
# MCP_ACCESS_MODE=read-only

# Kategorie-Flags (nur wirksam wenn MCP_ACCESS_MODE=custom):
#   MCP_ALLOW_CONTROL=true          – Gerätsteuerung (request_action, set_value, control_device, schedule_once)
#   MCP_ALLOW_KNOWLEDGE_WRITE=true  – Wissensbasis schreiben (knowledge_set, …)
#   MCP_ALLOW_AUTOMATION=true       – Skripte/Events erstellen & ausführen
#
# MCP_ALLOW_CONTROL=false
# MCP_ALLOW_KNOWLEDGE_WRITE=false
# MCP_ALLOW_AUTOMATION=false

# Feinsteuerung auf Tool-Ebene (kommagetrennte Tool-Namen):
#   MCP_TOOL_WHITELIST – diese Tools zusätzlich erlauben (höchste Priorität)
#   MCP_TOOL_BLACKLIST – diese Tools explizit sperren (wird zuletzt angewendet)
#
# Beispiel: nur ping und get_value erlauben:
#   MCP_TOOL_WHITELIST=symcon_ping,symcon_get_value
# Beispiel: run_script auch im full-Modus blockieren:
#   MCP_TOOL_BLACKLIST=symcon_run_script
#
# MCP_TOOL_WHITELIST=
# MCP_TOOL_BLACKLIST=
# ─────────────────────────────────────────────────────────────────────────────

# Ohne HTTPS starten (z. B. für Cursor): MCP_HTTP=1 ./start-mcp-local.sh
# Dann in Cursor http://127.0.0.1:4096 eintragen.
